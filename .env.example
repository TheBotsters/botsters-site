# PocketBase CMS URL — set per environment
# VPS local build:    http://127.0.0.1:8091  (staging) or http://127.0.0.1:8090 (prod)
# Cloudflare Pages:   set PB_URL in CF Pages project environment variables
#   Staging env:      https://cms-staging.botstersdev.com
#   Production env:   https://cms.botstersdev.com
PB_URL=http://127.0.0.1:8091
