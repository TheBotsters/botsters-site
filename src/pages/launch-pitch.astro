---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Launch Pitch"
  description="The Botsters — Fundamental Security for AI Agents."
>
  <div class="pitch-page">

    <!-- SLIDE 1: Title -->
    <section class="slide slide-title">
      <div class="slide-inner">
        <div class="slide-eyebrow">Presented by</div>
        <h1 class="presenter">Peter Kwangjun Suk</h1>
        <div class="title-lockup">
          <div class="company-name">The Botsters</div>
          <div class="tagline">10X the Security of OpenClaw, 10X the Market</div>
        </div>
      </div>
    </section>

    <div class="slide-divider"></div>

    <!-- SLIDE 2: The Problem -->
    <section class="slide slide-problem">
      <div class="slide-inner">
        <div class="slide-number">01</div>
        <div class="slide-label">The Problem</div>
        <h2>OpenClaw is Insecure.<br/>Very Insecure.</h2>

        <div class="evidence-block">
          <div class="evidence-item evidence-audit">
            <div class="evidence-icon">&#128269;</div>
            <div class="evidence-body">
              <div class="evidence-source">ClawSecure Large-Scale Security Audit</div>
              <div class="evidence-date">February 16, 2026</div>
              <div class="stat-grid">
                <div class="stat">
                  <div class="stat-num">41.7%</div>
                  <div class="stat-label">of skills contained vulnerabilities<br/><span class="stat-note">~1,205+ skills</span></div>
                </div>
                <div class="stat stat-danger">
                  <div class="stat-num">30.6%</div>
                  <div class="stat-label">High or Critical severity</div>
                </div>
                <div class="stat stat-warning">
                  <div class="stat-num">22.9%</div>
                  <div class="stat-label">"Sleeper Agent" risk</div>
                </div>
              </div>
            </div>
          </div>

          <div class="evidence-item evidence-quote">
            <div class="evidence-icon">&#128172;</div>
            <div class="evidence-body">
              <blockquote>
                "like I was defusing a bomb"
              </blockquote>
              <div class="quote-attribution">
                <strong>Summer Yue</strong>, Director of Alignment, Meta AI Security &amp; Safety
              </div>
              <div class="quote-detail">
                &mdash; on having to physically run to her Mac mini to shut down her OpenClaw agent
              </div>

            </div>
          </div>
        </div>

        <div class="root-access-box">
          &ldquo;Giving an AI Root Access to your Entire Life&rdquo;
        </div>
      </div>
    </section>

    <div class="slide-divider"></div>

    <!-- SLIDE 3: The Solution -->
    <section class="slide slide-solution">
      <div class="slide-inner">
        <div class="slide-number">02</div>
        <div class="slide-label">The Solution</div>
        <h2>Fundamental Security</h2>

        <ul class="solution-bullets">
          <li>A backplane to link and control <span class="bullet-accent">(Spine)</span></li>
          <li>Which separates the &ldquo;brain&rdquo; from the attack surfaces</li>
          <li>Secrets stay in the hands of the customer</li>
          <li>If the AI has no access to secrets, why attack?</li>
        </ul>
      </div>
    </section>

    <div class="slide-divider"></div>

    <!-- SLIDE 4: The Architecture -->
    <section class="slide slide-architecture">
      <div class="slide-inner">
        <div class="slide-number">03</div>
        <div class="slide-label">The Architecture</div>
        <h2>Brain &middot; Spine &middot; Actuator</h2>

        <div class="bsa-diagram">

