---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from '../../lib/pb.js';

// Fetch software items from CMS (active first, then beta, then deprecated)
const statusOrder = { active: 0, beta: 1, deprecated: 2 };
const raw = await getCollection("software");
const softwareItems = raw
  .sort((a, b) => (statusOrder[a.status] ?? 9) - (statusOrder[b.status] ?? 9))
  .map(item => {
    let links = {};
    try { links = typeof item.links === "string" ? JSON.parse(item.links) : (item.links || {}); } catch {}
    return { name: item.name, description: item.description, href: links.href || "#", icon: links.icon || "🔧", status: item.status };
  });
---

<BaseLayout title="Software" description="Open-source security infrastructure for AI agents">
  <section class="section">
    <div class="container">
      <h1>Software</h1>
      <p class="subtitle">Open-source tools for secure AI agent infrastructure.</p>

      <div class="software-grid">
        {softwareItems.map(item => (
          <a href={item.href} class={`software-card${item.status === 'deprecated' ? ' card-deprecated' : ''}`}>
            <div class="card-icon">{item.icon}</div>
            <h2>{item.name}</h2>
            <p>{item.description}</p>
            <span class="card-link">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <style>
    .subtitle {
      color: var(--color-text-muted, #888);
      font-size: 1.2rem;
      margin-bottom: 3rem;
    }

    .software-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }

    .software-card {
      background: #111;
      border: 1px solid #222;
      border-radius: 12px;
      padding: 2rem;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.2s, transform 0.2s;
      display: flex;
      flex-direction: column;
    }

    .software-card:hover {
      border-color: var(--color-accent, #e87400);
      transform: translateY(-2px);
    }

    .card-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }

    .software-card h2 {
      font-size: 1.4rem;
      margin-bottom: 0.75rem;
    }

    .software-card p {
      color: var(--color-text-muted, #888);
      font-size: 0.95rem;
      line-height: 1.6;
      flex-grow: 1;
    }

    .card-link {
      color: var(--color-accent, #e87400);
      font-weight: 600;
      margin-top: 1.5rem;
      font-size: 0.9rem;
    }
  </style>
</BaseLayout>
